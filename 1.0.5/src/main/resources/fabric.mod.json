{
  "schemaVersion": 1,
  "id": "endpoemfabric",
  "version": "1.0.5",
  "name": "Endpoem",
  "description": "Adds /endpoem command to replay the End Poem.",
  "authors": ["gta66666668"],
  "license": "MIT",
  "icon": "assets/endpoemfabric/icon.png",
  "environment": "*",

  "entrypoints": {
    "main": [
      "io.github.niubima.endpoemfabric.Endpoemfabric"
    ],
    "client": [
      "io.github.niubima.endpoemfabric.client.EndpoemfabricClient"
    ],
    "modmenu": [
      "io.github.niubima.endpoemfabric.client.compat.ModMenuCompat"
    ]
  },

  "mixins": [
    "endpoemfabric.mixins.json",
    {
      "config": "endpoemfabric.client.mixins.json",
      "environment": "client"
    }
  ],

  "contact": {
    "homepage": "https://github.com/gta66666668/Endpoem",
    "issues": "https://github.com/gta66666668/Endpoem/issues",
    "sources": "https://github.com/gta66666668/Endpoem"
  },

  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-api": "*",
    "cloth-config2": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
